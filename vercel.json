{
  "buildCommand": "cd react-app && npm install && npm run build",
  "outputDirectory": "react-app/dist",
  "rewrites": [
    {
      "source": "/favicon.ico",
      "destination": "/favicon.svg"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/journey",
      "destination": "/index.html"
    },
    {
      "source": "/yearbook",
      "destination": "/index.html"
    },
    {
      "source": "/vault",
      "destination": "/index.html"
    },
    {
      "source": "/wall",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}